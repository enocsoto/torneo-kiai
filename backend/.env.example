MONGODB_URI=mongodb://127.0.0.1:27029/torneo-kiai-tournament
PORT=4004
FRONTEND_ORIGIN=http://localhost:3000
# Modo invitado: máximo de batallas nuevas por hora y guestId (opcional en POST /battles)
GUEST_MAX_BATTLES_PER_HOUR=32
# Poblar MongoDB: npm run seed (con el API detenido o mientras corre; usa la misma URI)
# OpenAPI: npm run openapi:export → openapi.json ; UI interactiva: http://localhost:4004/docs
#
# ── Contacto (WhatsApp / Telegram) ───────────────────────────────────────────
# Origen recomendado en el API (el frontend las pide a GET /public/contact-links):
CONTACT_WHATSAPP=
# Solo dígitos, código país + móvil (ej. Argentina: 54911XXXXXXXX sin 15)
CONTACT_TELEGRAM=
# Usuario @telegram o el mismo número que WhatsApp (con o sin + / espacios)
# CONTACT_WHATSAPP_TEXT=
# Fallback si también definís NEXT_PUBLIC_* en el servicio del API (no hace falta en el front)
